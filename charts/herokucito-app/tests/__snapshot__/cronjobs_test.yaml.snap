renders cronjob referencing a service:
  1: |
    apiVersion: batch/v1
    kind: CronJob
    metadata:
      labels:
        app.kubernetes.io/component: cronjob
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/part-of: RELEASE-NAME
        helm.sh/chart: herokucito-app-0.1.0
      name: RELEASE-NAME-job-cleanup
    spec:
      concurrencyPolicy: Forbid
      failedJobsHistoryLimit: 1
      jobTemplate:
        spec:
          template:
            metadata:
              labels:
                app.kubernetes.io/component: cronjob
                app.kubernetes.io/managed-by: Helm
                app.kubernetes.io/part-of: RELEASE-NAME
                helm.sh/chart: herokucito-app-0.1.0
            spec:
              containers:
                - command:
                    - ./cleanup.sh
                  env:
                    - name: PORT
                      value: "8080"
                  image: myregistry/backend:v1.0.0
                  name: cleanup
                  resources:
                    limits:
                      cpu: 100m
                      memory: 256Mi
                    requests:
                      cpu: 20m
                      memory: 64Mi
              restartPolicy: OnFailure
              serviceAccountName: RELEASE-NAME
      schedule: 0 2 * * *
      successfulJobsHistoryLimit: 3
