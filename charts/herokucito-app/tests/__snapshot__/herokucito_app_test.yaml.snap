renders postgres in non-production mode:
  1: |
    apiVersion: postgresql.cnpg.io/v1
    kind: Cluster
    metadata:
      annotations:
        argocd.argoproj.io/sync-wave: "-20"
      labels:
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/part-of: RELEASE-NAME
        helm.sh/chart: herokucito-app-0.1.0
      name: RELEASE-NAME-db
    spec:
      bootstrap:
        initdb:
          database: appdb
          owner: app
          postInitSQL:
            - ALTER USER app WITH SUPERUSER;
      enablePDB: false
      instances: 1
      resources:
        limits:
          cpu: 500m
          memory: 512Mi
        requests:
          cpu: 100m
          memory: 128Mi
      storage:
        size: 5Gi
        storageClass: juicefs-cheap-shared
renders postgres in production mode:
  1: |
    apiVersion: postgresql.cnpg.io/v1
    kind: Cluster
    metadata:
      annotations:
        argocd.argoproj.io/sync-options: Delete=confirm
        argocd.argoproj.io/sync-wave: "-20"
      labels:
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/part-of: RELEASE-NAME
        helm.sh/chart: herokucito-app-0.1.0
      name: RELEASE-NAME-db
    spec:
      bootstrap:
        initdb:
          database: appdb
          owner: app
          postInitSQL:
            - ALTER USER app WITH SUPERUSER;
      enablePDB: true
      instances: 2
      resources:
        limits:
          cpu: 500m
          memory: 512Mi
        requests:
          cpu: 100m
          memory: 128Mi
      storage:
        size: 5Gi
renders service for a single service:
  1: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME-backend
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: backend
        app.kubernetes.io/part-of: RELEASE-NAME
        helm.sh/chart: herokucito-app-0.1.0
      name: RELEASE-NAME-backend
    spec:
      ports:
        - name: http
          port: 80
          protocol: TCP
          targetPort: http
      selector:
        app.kubernetes.io/component: server
        app.kubernetes.io/instance: RELEASE-NAME-backend
        app.kubernetes.io/name: backend
      type: ClusterIP
renders serviceaccount with defaults:
  1: |
    apiVersion: v1
    automountServiceAccountToken: false
    kind: ServiceAccount
    metadata:
      annotations:
        argocd.argoproj.io/sync-wave: "-20"
      labels:
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/part-of: RELEASE-NAME
        helm.sh/chart: herokucito-app-0.1.0
      name: RELEASE-NAME
