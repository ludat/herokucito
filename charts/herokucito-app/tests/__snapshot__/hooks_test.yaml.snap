renders hooks for pre-deploy and post-deploy with dependencies:
  1: |
    apiVersion: batch/v1
    kind: Job
    metadata:
      annotations:
        argocd.argoproj.io/hook: Sync
        argocd.argoproj.io/hook-delete-policy: BeforeHookCreation
        argocd.argoproj.io/sync-wave: "-10"
      labels:
        app.kubernetes.io/component: hook
        app.kubernetes.io/hook-type: pre-deploy
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/part-of: RELEASE-NAME
        helm.sh/chart: herokucito-app-0.1.0
      name: RELEASE-NAME-pre-migrate
    spec:
      template:
        metadata:
          labels:
            app.kubernetes.io/component: hook
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/part-of: RELEASE-NAME
            helm.sh/chart: herokucito-app-0.1.0
          name: RELEASE-NAME-pre-migrate
        spec:
          containers:
            - command:
                - ./migrate.sh
              env:
                - name: PORT
                  value: "8080"
                - name: BANANASPLIT_DATABASE_URL
                  valueFrom:
                    secretKeyRef:
                      key: uri
                      name: RELEASE-NAME-pg-app
                - name: DATABASE_URL
                  valueFrom:
                    secretKeyRef:
                      key: uri
                      name: RELEASE-NAME-pg-app
                - name: PGHOST
                  valueFrom:
                    secretKeyRef:
                      key: host
                      name: RELEASE-NAME-pg-app
                - name: PGPORT
                  valueFrom:
                    secretKeyRef:
                      key: port
                      name: RELEASE-NAME-pg-app
                - name: PGDATABASE
                  valueFrom:
                    secretKeyRef:
                      key: dbname
                      name: RELEASE-NAME-pg-app
                - name: PGUSER
                  valueFrom:
                    secretKeyRef:
                      key: user
                      name: RELEASE-NAME-pg-app
                - name: PGPASSWORD
                  valueFrom:
                    secretKeyRef:
                      key: password
                      name: RELEASE-NAME-pg-app
              image: myregistry/backend:v1.0.0
              name: migrate
              resources:
                limits:
                  cpu: 100m
                  memory: 256Mi
                requests:
                  cpu: 20m
                  memory: 64Mi
          restartPolicy: OnFailure
          serviceAccountName: RELEASE-NAME
  2: |
    apiVersion: batch/v1
    kind: Job
    metadata:
      annotations:
        argocd.argoproj.io/hook: Sync
        argocd.argoproj.io/hook-delete-policy: BeforeHookCreation
        argocd.argoproj.io/sync-wave: "10"
      labels:
        app.kubernetes.io/component: hook
        app.kubernetes.io/hook-type: post-deploy
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/part-of: RELEASE-NAME
        helm.sh/chart: herokucito-app-0.1.0
      name: RELEASE-NAME-post-notify
    spec:
      template:
        metadata:
          labels:
            app.kubernetes.io/component: hook
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/part-of: RELEASE-NAME
            helm.sh/chart: herokucito-app-0.1.0
          name: RELEASE-NAME-post-notify
        spec:
          containers:
            - command:
                - ./notify.sh
              env:
                - name: PORT
                  value: "8080"
                - name: BANANASPLIT_DATABASE_URL
                  valueFrom:
                    secretKeyRef:
                      key: uri
                      name: RELEASE-NAME-pg-app
                - name: DATABASE_URL
                  valueFrom:
                    secretKeyRef:
                      key: uri
                      name: RELEASE-NAME-pg-app
                - name: PGHOST
                  valueFrom:
                    secretKeyRef:
                      key: host
                      name: RELEASE-NAME-pg-app
                - name: PGPORT
                  valueFrom:
                    secretKeyRef:
                      key: port
                      name: RELEASE-NAME-pg-app
                - name: PGDATABASE
                  valueFrom:
                    secretKeyRef:
                      key: dbname
                      name: RELEASE-NAME-pg-app
                - name: PGUSER
                  valueFrom:
                    secretKeyRef:
                      key: user
                      name: RELEASE-NAME-pg-app
                - name: PGPASSWORD
                  valueFrom:
                    secretKeyRef:
                      key: password
                      name: RELEASE-NAME-pg-app
              image: myregistry/backend:v1.0.0
              name: notify
              resources:
                limits:
                  cpu: 100m
                  memory: 256Mi
                requests:
                  cpu: 20m
                  memory: 64Mi
          restartPolicy: OnFailure
          serviceAccountName: RELEASE-NAME
renders hooks with secrets:
  1: |
    apiVersion: batch/v1
    kind: Job
    metadata:
      annotations:
        argocd.argoproj.io/hook: Sync
        argocd.argoproj.io/hook-delete-policy: BeforeHookCreation
        argocd.argoproj.io/sync-wave: "-10"
      labels:
        app.kubernetes.io/component: hook
        app.kubernetes.io/hook-type: pre-deploy
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/part-of: RELEASE-NAME
        helm.sh/chart: herokucito-app-0.1.0
      name: RELEASE-NAME-pre-migrate
    spec:
      template:
        metadata:
          labels:
            app.kubernetes.io/component: hook
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/part-of: RELEASE-NAME
            helm.sh/chart: herokucito-app-0.1.0
          name: RELEASE-NAME-pre-migrate
        spec:
          containers:
            - command:
                - ./migrate.sh
              env:
                - name: PORT
                  value: "8080"
              envFrom:
                - secretRef:
                    name: my-app-secrets
                - secretRef:
                    name: my-api-keys
              image: myregistry/backend:v1.0.0
              name: migrate
              resources:
                limits:
                  cpu: 100m
                  memory: 256Mi
                requests:
                  cpu: 20m
                  memory: 64Mi
          restartPolicy: OnFailure
          serviceAccountName: RELEASE-NAME
